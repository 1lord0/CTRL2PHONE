{
  "name": "ctrl2phone",
  "version": "1.0.0",
  "description": "Capture any area of your screen with Double Ctrl, send it to Gemini Web or directly to your phone via Supabase.",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "tsc --watch",
    "build": "tsc",
    "package": "electron-builder",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "screenshot",
    "electron",
    "supabase",
    "screen-capture",
    "gemini",
    "mobile-sync"
  ],
  "author": "Eren",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1lord0/ctrl2phone"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "electron-updater": "^6.3.0",
    "qrcode": "^1.5.4",
    "screenshot-desktop": "^1.15.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  }
}
