# ============================================
# Ctrl2Phone — Monorepo .gitignore
# ============================================

# --- Desktop (Electron) ---
desktop/node_modules/
desktop/dist/
desktop/settings.json

# Compiled executables (users should build from source)
desktop/src/*.exe

# Compiled TypeScript output (do not commit)
desktop/src/*.js

# Personal launcher scripts
*.bat
*.vbs

# --- Mobile (Flutter) ---
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/*.iml
mobile/.idea/

# --- General ---
# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Gemini IDE
.gemini/

# Logs
*.log

# Misc
app-ads.txt
